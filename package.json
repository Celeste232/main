{
  "name": "cat-house",
  "version": "0.1.0",
  "description": "Desktop pet cat with house, food and water bowls",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "build:unpacked": "tsc -b && vite build && electron-builder --dir",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "slice": "node scripts/slice-frames.mjs"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.cathouse.app",
    "productName": "CatHouse",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.entertainment",
      "identity": null
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
