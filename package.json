{
  "name": "meow-mode",
  "version": "0.1.9",
  "description": "Meow Mode — 발그림 고양이가 데스크탑 위를 돌아다닙니다. A doodle kitten that wanders your desktop with its own little house, bowls, and chaotic charm.",
  "homepage": "https://github.com/Celeste232/main",
  "repository": {
    "type": "git",
    "url": "https://github.com/Celeste232/main.git"
  },
  "bugs": {
    "url": "https://github.com/Celeste232/main/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Celine Lee",
    "url": "https://github.com/Celeste232"
  },
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "build:unpacked": "tsc -b && vite build && electron-builder --dir",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "slice": "node scripts/slice-frames.mjs"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.celinelee.meowmode",
    "productName": "Meow Mode",
    "copyright": "Copyright © 2026 Celine Lee",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "afterPack": "build/afterPack.cjs",
    "files": [
      "dist",
      "dist-electron",
      "!**/.*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "build/icon.png"
      },
      {
        "from": "build/tray-icon.png",
        "to": "build/tray-icon.png"
      },
      {
        "from": "build/tray-icon-paused.png",
        "to": "build/tray-icon-paused.png"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Celeste232",
      "repo": "main"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.entertainment",
      "identity": null
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
